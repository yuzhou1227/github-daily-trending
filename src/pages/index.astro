---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

const dataPath = join(process.cwd(), 'data', 'data.json');
const allData = existsSync(dataPath) ? JSON.parse(readFileSync(dataPath, 'utf-8')) : {};
const dates = Object.keys(allData).sort().reverse();
const latestDate = dates[0] || '';
const todayData = latestDate ? allData[latestDate] : null;
const daily = todayData?.ranges?.daily || [];
const lastUpdated = todayData?.generatedAt || '';
const p0 = todayData?.ranges?.daily?.[0] || null;
const a0 = p0?.analysis;
---

<BaseLayout title="今日榜单" date={latestDate}>
  <Header />
  <main class="container main-layout">
    <aside class="left-panel">
      <div class="rank-list" id="rank-list-root">
        <div class="tab-bar">
          <span class="top-label">TOP 10 日榜</span>
          <div class="tab-group">
            <button class="tab-btn active" data-range="daily">每日</button>
            <button class="tab-btn" data-range="weekly">每周</button>
            <button class="tab-btn" data-range="monthly">每月</button>
          </div>
        </div>
        <ul class="items" id="rank-items">
          {daily.slice(0, 10).map((item, i) => (
            <li class="rank-item" class:list={{ active: i === 0 }}>
              <span class="rank-num">{String(item.rank).padStart(2, '0')}</span>
              <div class="rank-info">
                <span class="rank-name">{item.name}</span>
                <div class="rank-meta">
                  <span>{item.stars.toLocaleString()} stars</span>
                  {item.language && <span class="lang-tag">{item.language}</span>}
                  {item.weeklyAppearances > 1 && <span class="week-tag">周{item.weeklyAppearances}次</span>}
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </aside>
    <section class="center-panel" id="detail-panel">
      {p0 && a0 ? (
        <div class="project-detail">
          <div class="detail-header">
            <div class="detail-rank-badge">{String(p0.rank).padStart(2, '0')}</div>
            <h2 class="project-name">{p0.fullName}</h2>
            <p class="project-desc">{p0.description}</p>
            <div class="project-tags">
              {p0.language && <span class="tag lang">{p0.language}</span>}
              {p0.weeklyAppearances > 1 && <span class="tag weekly">本周上日榜 {p0.weeklyAppearances} 次</span>}
              <span class="tag stars">{p0.stars.toLocaleString()} stars</span>
              <span class="tag today">+{p0.starsRange.toLocaleString()} today</span>
            </div>
          </div>
          <div class="analysis-section">
            <div class="analysis-cards">
              <div class="analysis-card"><div class="card-header"><span class="card-num">1</span><h3 class="card-title">Core Idea</h3></div><p class="card-content">{a0.coreIdea}</p></div>
              <div class="analysis-card"><div class="card-header"><span class="card-num">2</span><h3 class="card-title">Engineering Method</h3></div><p class="card-content">{a0.engineeringMethod}</p></div>
              <div class="analysis-card highlight"><div class="card-header"><span class="card-num">3</span><h3 class="card-title">Why It Matters</h3></div><p class="card-content">{a0.whyItMatters}</p></div>
            </div>
            <div class="info-grid">
              <div class="info-section"><h3 class="info-label">Audience</h3>
                <div class="meta-row"><span class="meta-key">适合人群</span><span class="meta-val">{a0.audience}</span></div>
                <div class="meta-row"><span class="meta-key">难度</span><span class="meta-val diff">{a0.difficulty}</span></div>
              </div>
              <div class="info-section"><h3 class="info-label">Quick Start</h3>
                <div class="meta-row"><span class="meta-key">快速开始</span><span class="meta-val">{a0.quickStart}</span></div>
              </div>
            </div>
            {a0.whyItIsHot && <div class="hot-section"><h3 class="info-label">Why It Is Hot</h3><p>{a0.whyItIsHot}</p></div>}
            {a0.useCase && <div class="hot-section"><h3 class="info-label">Use Case</h3><p>{a0.useCase}</p></div>}
            <div class="repo-info">
              <span>{p0.stars.toLocaleString()} stars</span><span class="repo-stat sep">·</span>
              <span>+{p0.starsRange.toLocaleString()} today</span><span class="repo-stat sep">·</span>
              <span>{(p0.forks || '-').toLocaleString()} forks</span><span class="repo-stat sep">·</span>
              <span>{p0.language || 'N/A'}</span>
              <a href={`https://github.com/${p0.fullName}`} target="_blank" class="gh-link">View on GitHub →</a>
            </div>
          </div>
        </div>
      ) : (
        <div style="display:flex;align-items:center;justify-content:center;color:var(--text-tertiary);height:100%;font-size:14px">选择项目查看详情</div>
      )}
    </section>
    <aside class="right-panel" id="side-panel">
      {p0 ? (
        <div class="side-panel">
          <div class="panel-section"><h3 class="panel-title">仓库信息</h3>
            <div class="info-list">
              <div class="info-item"><span class="info-key">Stars</span><span class="info-val green">{p0.stars.toLocaleString()}</span></div>
              <div class="info-item"><span class="info-key">Today</span><span class="info-val red">+{p0.starsRange.toLocaleString()}</span></div>
              <div class="info-item"><span class="info-key">Forks</span><span class="info-val">{(p0.forks || '-').toLocaleString()}</span></div>
              <div class="info-item"><span class="info-key">Language</span><span class="info-val">{p0.language || 'N/A'}</span></div>
            </div>
          </div>
          <a href={`https://github.com/${p0.fullName}`} target="_blank" class="gh-btn">View on GitHub</a>
        </div>
      ) : (
        <div style="padding:40px 0;text-align:center;color:var(--text-tertiary);font-size:13px">选择项目以查看详情</div>
      )}
    </aside>
  </main>
  {lastUpdated && (
    <div class="status-bar container">
      <span class="update-info">上次更新 {new Date(lastUpdated).toLocaleString('zh-CN')}</span>
      {Date.now() - new Date(lastUpdated).getTime() > 26 * 3600000 && (
        <span class="stale-warning">数据已超过 24 小时未更新</span>
      )}
    </div>
  )}
  <Footer />
</BaseLayout>

<script define:vars={{ allData, latestDate }}>
  const data = allData[latestDate];
  if (!data) throw new Error('no data');

  function html(t, ...v) {
    let r = t[0];
    for (let i = 0; i < v.length; i++) r += String(v[i]) + t[i + 1];
    return r;
  }

  function esc(s) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function pad(n) { return String(n).padStart(2, '0'); }

  function renderProjectDetail(p) {
    if (!p) return '<div style="display:flex;align-items:center;justify-content:center;color:var(--text-tertiary);height:100%;font-size:14px">选择项目查看详情</div>';
    const a = p.analysis;
    const analysisCards = a ? html`
    <div class="analysis-cards">
      <div class="analysis-card"><div class="card-header"><span class="card-num">1</span><h3 class="card-title">Core Idea</h3></div><p class="card-content">${esc(a.coreIdea)}</p></div>
      <div class="analysis-card"><div class="card-header"><span class="card-num">2</span><h3 class="card-title">Engineering Method</h3></div><p class="card-content">${esc(a.engineeringMethod)}</p></div>
      <div class="analysis-card highlight"><div class="card-header"><span class="card-num">3</span><h3 class="card-title">Why It Matters</h3></div><p class="card-content">${esc(a.whyItMatters)}</p></div>
    </div>
    <div class="info-grid">
      <div class="info-section"><h3 class="info-label">Audience</h3>
        <div class="meta-row"><span class="meta-key">适合人群</span><span class="meta-val">${esc(a.audience)}</span></div>
        <div class="meta-row"><span class="meta-key">难度</span><span class="meta-val diff">${esc(a.difficulty)}</span></div>
      </div>
      <div class="info-section"><h3 class="info-label">Quick Start</h3>
        <div class="meta-row"><span class="meta-key">快速开始</span><span class="meta-val">${esc(a.quickStart)}</span></div>
      </div>
    </div>
    ${a.whyItIsHot ? `<div class="hot-section"><h3 class="info-label">Why It Is Hot</h3><p>${esc(a.whyItIsHot)}</p></div>` : ''}
    ${a.useCase ? `<div class="hot-section"><h3 class="info-label">Use Case</h3><p>${esc(a.useCase)}</p></div>` : ''}`
    : '';
    return html`
<div class="project-detail">
  <div class="detail-header">
    <div class="detail-rank-badge">${pad(p.rank)}</div>
    <h2 class="project-name">${esc(p.fullName)}</h2>
    <p class="project-desc">${esc(p.description)}</p>
    <div class="project-tags">
      ${p.language ? `<span class="tag lang">${esc(p.language)}</span>` : ''}
      ${p.weeklyAppearances > 1 ? `<span class="tag weekly">本周上日榜 ${p.weeklyAppearances} 次</span>` : ''}
      <span class="tag stars">${p.stars.toLocaleString()} stars</span>
      <span class="tag today">+${p.starsRange.toLocaleString()} today</span>
    </div>
  </div>
  <div class="analysis-section">
    ${analysisCards}
    <div class="repo-info">
      <span>${p.stars.toLocaleString()} stars</span><span class="repo-stat sep">·</span>
      <span>+${p.starsRange.toLocaleString()} today</span><span class="repo-stat sep">·</span>
      <span>${(p.forks || '-').toLocaleString()} forks</span><span class="repo-stat sep">·</span>
      <span>${esc(p.language || 'N/A')}</span>
      <a href="https://github.com/${esc(p.fullName)}" target="_blank" class="gh-link">View on GitHub →</a>
    </div>
  </div>
</div>`;
  }

  function renderSidePanel(p) {
    if (!p) return '<div style="padding:40px 0;text-align:center;color:var(--text-tertiary);font-size:13px">选择项目以查看详情</div>';
    return html`
<div class="side-panel">
  <div class="panel-section"><h3 class="panel-title">仓库信息</h3>
    <div class="info-list">
      <div class="info-item"><span class="info-key">Stars</span><span class="info-val green">${p.stars.toLocaleString()}</span></div>
      <div class="info-item"><span class="info-key">Today</span><span class="info-val red">+${p.starsRange.toLocaleString()}</span></div>
      <div class="info-item"><span class="info-key">Forks</span><span class="info-val">${(p.forks || '-').toLocaleString()}</span></div>
      <div class="info-item"><span class="info-key">Language</span><span class="info-val">${esc(p.language || 'N/A')}</span></div>
    </div>
  </div>
  <a href="https://github.com/${esc(p.fullName)}" target="_blank" class="gh-btn">View on GitHub</a>
</div>`;
  }

  function renderRankItems(items, activeIndex) {
    return items.slice(0, 10).map((item, i) => html`
<li class="rank-item${i === activeIndex ? ' active' : ''}" data-index="${i}">
  <span class="rank-num">${pad(item.rank)}</span>
  <div class="rank-info">
    <span class="rank-name">${esc(item.name)}</span>
    <div class="rank-meta">
      <span>${item.stars.toLocaleString()} stars</span>
      ${item.language ? `<span class="lang-tag">${esc(item.language)}</span>` : ''}
      ${item.weeklyAppearances > 1 ? `<span class="week-tag">周${item.weeklyAppearances}次</span>` : ''}
    </div>
  </div>
</li>`).join('');
  }

  const detailPanel = document.getElementById('detail-panel');
  const sidePanel = document.getElementById('side-panel');
  const itemsContainer = document.getElementById('rank-items');
  const rankListRoot = document.getElementById('rank-list-root');

  function getState() {
    const p = new URLSearchParams(window.location.search);
    const range = p.get('range') || 'daily';
    const idx = parseInt(p.get('index')) || 0;
    const items = data.ranges[range] || [];
    return {
      range: ['daily', 'weekly', 'monthly'].includes(range) ? range : 'daily',
      index: idx >= 0 && idx < items.length ? idx : 0,
    };
  }

  function setState(range, index) {
    const url = new URL(window.location);
    url.searchParams.set('range', range);
    url.searchParams.set('index', index);
    window.history.pushState({ range, index }, '', url.toString());
  }

  function render(state) {
    const items = data.ranges[state.range] || [];
    const project = items[state.index] || null;

    rankListRoot.querySelectorAll('.tab-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.range === state.range);
    });
    const labels = { daily: '日榜', weekly: '周榜', monthly: '月榜' };
    rankListRoot.querySelector('.top-label').textContent = `TOP 10 ${labels[state.range]}`;
    itemsContainer.innerHTML = renderRankItems(items, state.index);
    detailPanel.innerHTML = renderProjectDetail(project);
    sidePanel.innerHTML = renderSidePanel(project);
  }

  rankListRoot.addEventListener('click', (e) => {
    const item = e.target.closest('.rank-item');
    if (item) {
      const idx = parseInt(item.dataset.index);
      if (isNaN(idx)) return;
      const st = getState();
      if (idx === st.index) return;
      setState(st.range, idx);
      render(getState());
      return;
    }
    const btn = e.target.closest('.tab-btn');
    if (btn) {
      const range = btn.dataset.range;
      const st = getState();
      if (range === st.range) return;
      setState(range, 0);
      render(getState());
      return;
    }
  });

  window.addEventListener('popstate', () => { render(getState()); });

  const initial = getState();
  render(initial);
  if (initial.range !== 'daily' || initial.index !== 0) {
    setState(initial.range, initial.index);
  }
</script>
