---
export interface Props {
  number: number;
  title: string;
  content: string;
  highlight?: boolean;
}

const { number, title, content, highlight } = Astro.props;
---

<div class="analysis-card" class:list={{ highlight }}>
  <div class="card-header">
    <span class="card-num">{number}</span>
    <h3 class="card-title">{title}</h3>
  </div>
  <p class="card-content">{content}</p>
</div>

<style>
  .analysis-card {
    background: var(--bg-surface);
    border-radius: 10px;
    padding: 16px;
    border: 1px solid var(--border-light);
    transition: border-color 0.15s;
  }
  .analysis-card.highlight {
    border-color: rgba(210, 153, 34, 0.4);
    background: linear-gradient(135deg, rgba(210, 153, 34, 0.05), var(--bg-surface) 60%);
    box-shadow: inset 0 0 0 1px rgba(210, 153, 34, 0.1);
  }
  .card-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }
  .card-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(139, 148, 158, 0.15);
    color: var(--text-secondary);
    font-size: 11px;
    font-weight: 700;
    font-family: var(--font-mono);
    flex-shrink: 0;
  }
  .analysis-card.highlight .card-num {
    background: rgba(210, 153, 34, 0.2);
    color: var(--accent-gold);
  }
  .card-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--text-secondary);
  }
  .analysis-card.highlight .card-title {
    color: var(--accent-gold);
  }
  .card-content {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-primary);
  }
</style>
