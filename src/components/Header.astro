---
// Header component
---

<header class="header">
  <div class="container header-inner">
    <div class="brand">
      <h1 class="brand-title">GitHub 热榜</h1>
      <span class="brand-badge">LIVE TOP 10</span>
    </div>
    <nav class="nav">
      <a href="/github-daily-trending/" class="nav-link active">今日</a>
      <a href="/github-daily-trending/archive" class="nav-link">归档</a>
    </nav>
  </div>
</header>

<style>
  .header {
    border-bottom: 1px solid var(--border);
    padding: 14px 0;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand { display: flex; align-items: baseline; gap: 12px; }
  .brand-title {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 1px;
    background: linear-gradient(135deg, var(--accent-orange), var(--accent-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .brand-badge {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--accent-blue);
    background: rgba(88, 166, 255, 0.1);
    padding: 3px 8px;
    border-radius: 4px;
    font-family: var(--font-mono);
  }
  .nav { display: flex; gap: 4px; }
  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: 6px;
    transition: all 0.15s;
  }
  .nav-link:hover {
    color: var(--text-primary);
    background: var(--bg-hover);
    text-decoration: none;
  }
  .nav-link.active {
    color: var(--text-primary);
    background: var(--bg-hover);
  }
</style>
