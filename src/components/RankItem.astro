---
export interface Props {
  rank: number;
  name: string;
  fullName: string;
  stars: number;
  starsRange: number;
  language: string;
  isActive: boolean;
  analysis: any | null;
  weeklyAppearances: number;
}

const { rank, name, stars, language, isActive, analysis, weeklyAppearances } = Astro.props;
---

<li class="rank-item" class:list={{ active: isActive }}>
  <span class="rank-num">#{rank}</span>
  <div class="rank-info">
    <span class="rank-name">{name}</span>
    <div class="rank-meta">
      <span class="stars">{stars.toLocaleString()} stars</span>
      {language && <span class="lang-tag">{language}</span>}
      {weeklyAppearances > 1 && <span class="week-tag">周{weeklyAppearances}次</span>}
    </div>
  </div>
  {analysis === null && <span class="pending-badge">分析中</span>}
</li>

<style>
  .rank-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.15s;
    list-style: none;
    border: 1px solid transparent;
  }
  .rank-item:hover { background: var(--bg-hover); }
  .rank-item.active {
    background: rgba(88, 166, 255, 0.08);
    border-color: rgba(88, 166, 255, 0.3);
  }
  .rank-num {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 15px;
    color: var(--accent-orange);
    min-width: 30px;
  }
  .rank-info { flex: 1; min-width: 0; }
  .rank-name {
    font-weight: 600;
    font-size: 14px;
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--accent-blue);
  }
  .rank-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 2px;
  }
  .lang-tag {
    background: rgba(139, 148, 158, 0.1);
    color: var(--text-secondary);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 11px;
  }
  .week-tag {
    background: rgba(188, 140, 255, 0.1);
    color: var(--accent-purple);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 11px;
  }
  .pending-badge {
    font-size: 11px;
    color: var(--text-secondary);
    background: var(--bg-hover);
    padding: 2px 6px;
    border-radius: 4px;
  }
</style>
