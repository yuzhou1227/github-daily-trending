---
export interface Props {
  project: any | null;
}

const { project } = Astro.props;
---

<div class="side-panel">
  {project ? (
    <>
      <div class="panel-section">
        <h3 class="panel-title">仓库信息</h3>
        <div class="info-list">
          <div class="info-item">
            <span class="info-key">★ Stars</span>
            <span class="info-val green">{project.stars.toLocaleString()}</span>
          </div>
          <div class="info-item">
            <span class="info-key">▲ 今日涨星</span>
            <span class="info-val red">+{project.starsRange.toLocaleString()}</span>
          </div>
          <div class="info-item">
            <span class="info-key">⑂ Forks</span>
            <span class="info-val">{project.forks?.toLocaleString() || '-'}</span>
          </div>
          <div class="info-item">
            <span class="info-key">🔤 语言</span>
            <span class="info-val">{project.language || 'N/A'}</span>
          </div>
        </div>
      </div>
      <a href={`https://github.com/${project.fullName}`} target="_blank" class="gh-btn">
        在 GitHub 上查看 →
      </a>
    </>
  ) : (
    <div class="empty-side">
      <p>选择项目查看详情</p>
    </div>
  )}
</div>

<style>
  .side-panel { display: flex; flex-direction: column; gap: 12px; }
  .panel-section {
    background: var(--bg-surface);
    border: 1px solid var(--border-light);
    border-radius: 10px;
    padding: 14px;
  }
  .panel-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--accent-orange);
    margin-bottom: 10px;
  }
  .info-list { display: flex; flex-direction: column; }
  .info-item {
    display: flex;
    justify-content: space-between;
    padding: 6px 0;
    border-bottom: 1px solid var(--border-light);
    font-size: 13px;
  }
  .info-item:last-child { border-bottom: none; }
  .info-key { color: var(--text-secondary); }
  .info-val { font-family: var(--font-mono); font-weight: 500; color: var(--text-primary); }
  .info-val.green { color: var(--accent-green); }
  .info-val.red { color: var(--accent-red); }
  .gh-btn {
    display: block;
    text-align: center;
    padding: 10px;
    background: rgba(88, 166, 255, 0.1);
    color: var(--accent-blue);
    border: 1px solid rgba(88, 166, 255, 0.3);
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 13px;
    transition: all 0.15s;
  }
  .gh-btn:hover {
    background: rgba(88, 166, 255, 0.2);
    text-decoration: none;
  }
  .empty-side {
    text-align: center;
    color: var(--text-secondary);
    font-size: 14px;
    padding: 40px 0;
  }
</style>
